@implements IDisposable
@inject AppUpdateService UpdateService
@inject TemplateMetadata Metadata

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid brand-block">
        <div>
            <a class="navbar-brand" href="">@Metadata.ShortName</a>
        </div>
    </div>
</div>

<input type="checkbox" title="Navigation menu" class="navbar-toggler" />

<div class="nav-scrollable" onclick="document.querySelector('.navbar-toggler').click()">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-link-label">
                    <i class="bi bi-house" aria-hidden="true"></i>
                    <span>Home</span>
                </span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="persistence">
                <span class="nav-link-label">
                    <i class="bi bi-device-hdd" aria-hidden="true"></i>
                    <span>Persistence</span>
                </span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="documentation">
                <span class="nav-link-label">
                    <i class="bi bi-file-earmark-text" aria-hidden="true"></i>
                    <span>Documentation</span>
                </span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link nav-link-menu" href="settings">
                <span class="nav-link-label">
                    <i class="bi bi-gear" aria-hidden="true"></i>
                    <span>Settings</span>
                </span>
                @if (_showSettingsBadge)
                {
                    <span class="badge rounded-pill text-bg-warning nav-badge">?</span>
                }
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool _showSettingsBadge;

    protected override async Task OnInitializedAsync()
    {
        UpdateService.SnapshotChanged += HandleSnapshotChanged;
        ApplySnapshot(UpdateService.GetSnapshot());
        await UpdateService.EnsureStartupCheckAsync();
        ApplySnapshot(UpdateService.GetSnapshot());
    }

    private void HandleSnapshotChanged()
    {
        ApplySnapshot(UpdateService.GetSnapshot());
        _ = InvokeAsync(StateHasChanged);
    }

    private void ApplySnapshot(AppUpdateSnapshot snapshot)
    {
        _showSettingsBadge = snapshot.IsUpdateAvailable;
    }

    public void Dispose()
    {
        UpdateService.SnapshotChanged -= HandleSnapshotChanged;
    }
}
