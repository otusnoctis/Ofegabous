@page "/"
@inject TemplateMetadata Metadata
@inject TemplateEnvironment Environment
@inject AppUpdateService UpdateService

<PageTitle>Home</PageTitle>

<header class="page-header">
    <h1 class="page-title">Home</h1>
    <p class="page-summary">
        Overview of the template, its base architecture, and the current runtime state.
    </p>
</header>

<section class="hero-panel">
    <p class="eyebrow">Template app</p>
    <h2>@Metadata.DisplayName</h2>
    <p class="hero-copy">
        This application is the base of a Windows template for local tools.
        The goal is to reuse the shell, persistence, and update flow without mixing in product-specific business logic yet.
    </p>
</section>

<section class="home-grid">
    <div class="content-card">
        <h2>Key features</h2>
        <ul>
            <li>Windows-only with `.NET MAUI` + `BlazorWebView`.</li>
            <li>Simple JSON local persistence that can be replaced later.</li>
            <li>Markdown documentation served from the repo filesystem or the published app.</li>
            <li>`Velopack` updates delivered through `GitHub Releases`.</li>
            <li>Shared configuration centralized in `Directory.Build.props`.</li>
        </ul>
    </div>

    <div class="content-card">
        <h2>Architecture</h2>
        <ul>
            <li>`Layout`: the main shell and side navigation.</li>
            <li>`Pages`: `Home`, `Persistence`, `Documentation`, and `Settings` as the functional baseline.</li>
            <li>`Services`: metadata, environment, persistence, documentation, and update services.</li>
            <li>`scripts` + `.github`: packaging and tag-driven releases.</li>
        </ul>
    </div>

    <div class="content-card">
        <h2>Runtime model</h2>
        <ul>
            <li>In development it uses the repo root as the base directory.</li>
            <li>Local data lives in `@Environment.DataDirectory`.</li>
            <li>Update checks run only for valid Velopack installations.</li>
            <li>`Settings` concentrates versioning, update state, and actions.</li>
        </ul>
    </div>

    <div class="content-card">
        <h2>Current state</h2>
        <dl class="detail-list">
            <dt>Mode</dt>
            <dd>@(Environment.IsDevelopmentMode ? "Development" : "Installed runtime")</dd>
            <dt>Update repository</dt>
            <dd>@_snapshot.RepositoryUrl</dd>
            <dt>Persistence file</dt>
            <dd>@Environment.PersistenceFilePath</dd>
        </dl>
    </div>
</section>

@code {
    private AppUpdateSnapshot _snapshot = default!;

    protected override void OnInitialized()
    {
        _snapshot = UpdateService.GetSnapshot();
    }
}
