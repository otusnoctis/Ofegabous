@page "/settings"
@implements IDisposable
@inject AppUpdateService UpdateService
@inject UpdateLogStore UpdateLogStore
@inject SystemShellService SystemShellService

<PageTitle>Settings</PageTitle>

<header class="page-header">
    <h1 class="page-title">Settings</h1>
    <p class="page-summary">
        Versioning state, update runtime status, and recent update activity.
    </p>
</header>

@if (_snapshot is null)
{
    <p>Loading...</p>
}
else
{
    <div class="settings-stack">
        <section class="settings-card">
            <h2>Versions</h2>
            <dl class="settings-details">
                <div class="settings-detail-item">
                    <dt>App</dt>
                    <dd>@_snapshot.AppVersion</dd>
                </div>
                <div class="settings-detail-item">
                    <dt>Velopack</dt>
                    <dd>@_snapshot.VelopackVersion</dd>
                </div>
                <div class="settings-detail-item settings-detail-item-wide">
                    <dt>Update repository</dt>
                    <dd>@_snapshot.RepositoryUrl</dd>
                </div>
            </dl>
        </section>

        <section class="settings-card">
            <div class="settings-header">
                <div>
                    <h2>Updates</h2>
                    <p class="text-body-secondary mb-0">@GetStatusSummary()</p>
                </div>
                @if (_snapshot.IsUpdateAvailable)
                {
                    <span class="badge text-bg-warning">Pending</span>
                }
                else if (!_snapshot.IsDevMode)
                {
                    <span class="badge text-bg-success">Up to date</span>
                }
            </div>

            <div class="@GetUpdateAlertClass()" role="status">
                <strong>@GetUpdateHeadline()</strong>
                <div>@_snapshot.UpdateMessage</div>
            </div>

            @if (_snapshot.LastCheckedAt is not null)
            {
                <p class="text-body-secondary mt-3 mb-0">
                    Last check: @_snapshot.LastCheckedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")
                </p>
            }

            <div class="mt-3 d-flex gap-2 flex-wrap">
                @if (!_snapshot.IsDevMode)
                {
                    @if (_snapshot.IsUpdateAvailable)
                    {
                        <button class="btn btn-primary"
                                disabled="@(_isBusy || !_snapshot.CanCheckUpdates)"
                                @onclick="UpdateNowAsync">
                            @(_isBusy ? "Processing..." : "Update now")
                        </button>
                    }

                    <button class="btn btn-outline-primary"
                            disabled="@(_isBusy || !_snapshot.CanCheckUpdates)"
                            @onclick="CheckForUpdatesAsync">
                        @(_isBusy ? "Checking..." : "Check again")
                    </button>
                }

                <button class="btn btn-outline-primary"
                        @onclick="ToggleLogAsync">
                    @(_showUpdateLog ? "Hide log" : "View log")
                </button>
            </div>

            @if (_showUpdateLog)
            {
                <div class="settings-log-panel">
                    <div class="settings-log-header">
                        <div>
                            <h3>Update log</h3>
                            <p class="text-body-secondary mb-0">Latest events stored in `logs/update-log.json`.</p>
                        </div>
                        <button class="btn btn-outline-primary btn-sm"
                                @onclick="OpenRawLogFile">
                            Open raw file
                        </button>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(_logActionMessage))
                    {
                        <p class="settings-log-action-message">@_logActionMessage</p>
                    }

                    @if (!string.IsNullOrWhiteSpace(_progressMessage))
                    {
                        <p class="text-primary fw-semibold mt-3 mb-0">@_progressMessage</p>
                    }

                    @if (_updateLogEntries.Count == 0)
                    {
                        <p class="mb-0 mt-3">No update events have been logged yet.</p>
                    }
                    else
                    {
                        <div class="settings-log-list">
                            @foreach (var entry in _updateLogEntries)
                            {
                                <article class="settings-log-entry">
                                    <div class="settings-log-meta">
                                        <time>@entry.TimestampUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm:ss")</time>
                                        <span>@entry.EventType</span>
                                    </div>
                                    <p class="settings-log-message">@entry.Message</p>
                                </article>
                            }
                        </div>
                    }
                </div>
            }
        </section>
    </div>
}

@code {
    private AppUpdateSnapshot? _snapshot;
    private IReadOnlyList<UpdateLogEntry> _updateLogEntries = [];
    private bool _isBusy;
    private bool _showUpdateLog;
    private string? _logActionMessage;
    private string _progressMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        _snapshot = UpdateService.GetSnapshot();
        UpdateService.SnapshotChanged += HandleSnapshotChanged;
        await UpdateService.EnsureStartupCheckAsync();
        _snapshot = UpdateService.GetSnapshot();
        await RefreshUpdateLogAsync();
    }

    private async Task CheckForUpdatesAsync()
    {
        if (_snapshot is null || !_snapshot.CanCheckUpdates || _isBusy)
        {
            return;
        }

        _isBusy = true;
        _progressMessage = string.Empty;
        StateHasChanged();

        _snapshot = await UpdateService.CheckForUpdatesAsync(message =>
        {
            _progressMessage = message;
            _ = InvokeAsync(StateHasChanged);
        });

        _progressMessage = string.Empty;
        _isBusy = false;
        await RefreshUpdateLogAsync();
    }

    private async Task UpdateNowAsync()
    {
        if (_snapshot is null || !_snapshot.CanCheckUpdates || _isBusy)
        {
            return;
        }

        _isBusy = true;
        _progressMessage = string.Empty;
        StateHasChanged();

        var result = await UpdateService.DownloadAndApplyAsync(message =>
        {
            _progressMessage = message;
            _ = InvokeAsync(StateHasChanged);
        });

        _snapshot = result.Snapshot;
        _progressMessage = result.ProgressMessage;
        _isBusy = false;
        await RefreshUpdateLogAsync();
    }

    private void HandleSnapshotChanged()
    {
        _snapshot = UpdateService.GetSnapshot();
        _ = InvokeAsync(async () =>
        {
            await RefreshUpdateLogAsync();
            StateHasChanged();
        });
    }

    private async Task ToggleLogAsync()
    {
        _showUpdateLog = !_showUpdateLog;
        _logActionMessage = null;
        if (_showUpdateLog)
        {
            await RefreshUpdateLogAsync();
        }
    }

    private void OpenRawLogFile()
    {
        _logActionMessage = SystemShellService.TryOpenFile(UpdateLogStore.LogFilePath)
            ? null
            : "The raw update log file could not be opened.";
    }

    private async Task RefreshUpdateLogAsync()
    {
        _updateLogEntries = await UpdateLogStore.LoadRecentAsync();
    }

    private string GetStatusSummary()
    {
        if (_snapshot is null)
        {
            return "Loading update status.";
        }

        if (_snapshot.IsDevMode)
        {
            return "Updates do not run in development mode.";
        }

        if (!_snapshot.IsInstalled)
        {
            return "The app is not installed through Velopack, so the update runtime is disabled.";
        }

        if (_snapshot.IsUpdateAvailable)
        {
            return $"A new version is available: {_snapshot.AvailableVersion}.";
        }

        return "There are no pending updates.";
    }

    private string GetUpdateHeadline()
    {
        if (_snapshot is null)
        {
            return "Loading";
        }

        if (_snapshot.IsDevMode)
        {
            return "Updates disabled";
        }

        if (_snapshot.IsUpdateAvailable)
        {
            return $"Update available: {_snapshot.AvailableVersion}";
        }

        return "Application up to date";
    }

    private string GetUpdateAlertClass()
    {
        if (_snapshot is null || _snapshot.IsDevMode || !_snapshot.IsInstalled)
        {
            return "alert alert-secondary mb-0";
        }

        return _snapshot.IsUpdateAvailable
            ? "alert alert-warning mb-0"
            : "alert alert-success mb-0";
    }

    public void Dispose()
    {
        UpdateService.SnapshotChanged -= HandleSnapshotChanged;
    }
}
